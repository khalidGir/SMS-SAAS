# Base URL of the deployed Express API server
# Examples: http://localhost:4000, https://sms-api.onrender.com
API_PROXY_URL=https://your-backend-url.com

# Chapa payment gateway secret key (leave empty for mock/dev mode)
# CHAPA_SECRET_KEY=your_chapa_secret_key_here

# DeboPay payment gateway (leave empty for mock/dev mode)
# DEBO_SECRET_KEY=dp_test_...
# DEBO_WEBHOOK_SECRET= (optional, falls back to DEBO_SECRET_KEY)

# Public URL of this backend (used for gateway callback_urls)
# APP_URL=http://localhost:4000
